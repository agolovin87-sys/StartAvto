VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Яндекс.Карты: вкладка GPS у админа (JavaScript API). Кабинет: https://developer.tech.yandex.ru/services/
# VITE_YANDEX_MAPS_API_KEY=
# Яндекс Suggest API: адресные подсказки в поле «Адрес» у курсанта
# (в некоторых проектах нужен отдельный ключ suggest_apikey).
# VITE_YANDEX_SUGGEST_API_KEY=

# Яндекс Локатор (уточнение по IP инструктора) — только Secret для Cloud Functions, не VITE_:
#   firebase functions:secrets:set YANDEX_LOCATOR_API_KEY
# Затем: firebase deploy --only functions:locatorLocate
# Документация: https://yandex.ru/maps-api/docs/locator/request.html

# Web Push (FCM): пара ключей в Firebase Console → Project settings → Cloud Messaging → Web Push certificates
# Без этого push с Cloud Functions не подключатся на клиенте.
# VITE_FIREBASE_VAPID_KEY=

# Публичный HTTPS-оригинал сайта (без слэша в конце). Нужен для og:image в index.html — превью ссылок в Telegram, WhatsApp и др.
# Если не задано, при сборке подставляется https://startavto-cf419.web.app
# VITE_PUBLIC_SITE_ORIGIN=https://your-domain.example

# Через запятую email администраторов (получат роль admin при входе)
VITE_ADMIN_EMAILS=admin@example.com

# Опционально: UID документа админа в Firestore (если контакт «Администратор» не подтягивается)
# VITE_PRIMARY_ADMIN_UID=

# Те же адреса продублируйте в firestore.rules (массив adminEmailsList) и выполните:
# firebase deploy --only firestore:rules
# Иначе коллекция groups и др. могут отвечать «Missing or insufficient permissions».
